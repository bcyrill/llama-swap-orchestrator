# Copy to /etc/llama-swap/llama-swap.env and edit. Read by systemd as
# the orchestrator's EnvironmentFile (see llama-swap/llama-swap.container).

# Where models live on the host. Will contain:
#   $LLAMA_MODELS_DIR/gguf/      <- GGUF files for llama.cpp
#   $LLAMA_MODELS_DIR/hf-cache/  <- shared Hugging Face cache for vLLM + SGLang
#
# Must match socket-proxy/config.yaml's
# body_policies.llama_swap_create.binds.allowed_sources entry — the
# proxy denies bind sources outside that prefix. If you change this,
# also update the policy and re-run scripts/validate-proxy-config.sh.
LLAMA_MODELS_DIR=/srv/llama-models

# Hugging Face token. Required for gated repos (e.g. meta-llama/*).
# Leave as empty string for public-only models.
HF_TOKEN=
