# Per-model subuid/subgid range allocation.
#
# Each container gets its own non-overlapping 65536-block, matching the
# convention used by the rest of your stack (Traefik 0:100000:65536, etc.).
# Format: BASE   = the host UID to which container UID 0 is mapped.
#         SIZE   = 65536 (so container UIDs 0..65535 -> host UIDs BASE..BASE+65535).
#
# Reserve a clear gap above your existing services. These defaults start at
# 500000 — change them if any of these collide with an existing range.
#
# Sourced by:
#   - scripts/init-cache-dirs.sh                (chowns per-model cache subdirs)
# Mirrored (manually) by:
#   - llama-swap/config.yaml                    (--uidmap / --gidmap on each cmd:)
#   - llama-swap/llama-swap.container           (UidMap= / GidMap= on the orchestrator)

# Map: MODEL_ID -> BASE_UID
# llama-swap-orchestrator is the orchestrator container itself; with the
# socket-proxy in the loop it can run under its own UID range like every
# model container.
declare -A LLAMA_SWAP_UIDS=(
  [llamacpp-qwen2.5-7b]=500000
  [llamacpp-bge-reranker]=600000
  [vllm-llama3.1-8b]=700000
  [sglang-qwen2.5-14b]=800000
  [llama-swap-orchestrator]=900000
)

# All ranges are 65536 wide.
LLAMA_SWAP_RANGE_SIZE=65536
